# fpga_gameconsole/Makefile — Global build orchestrator
#
# Build & Run:
#   make all                                                — build all games, all platforms
#   make build GAME=<game> ARCH=<arch>                      — build ROM only
#   make build GAME=<game> TARGET=sdl2                      — build native SDL2 binary
#   make run   GAME=<game> ARCH=<arch> TARGET=<target>      — build + run
#   make clean                                              — clean build artifacts
#
# Targets (TARGET=):
#   sdl2      — native desktop build (gcc + SDL2)
#   verilator — desktop sim running actual Verilog (Verilator + SDL2)
#   fpga      — yosys/nextpnr synthesis to bitfile for real hardware
#   gtkwave   — iverilog simulation to VCD waveform
#
# Hardware version (HW=, applies only to ARCH=risc2 + TARGET=fpga):
#   v1        — two SDR SDRAMs (default), uses project-risc2-video-hw1.lpf
#   v2        — single DDR3 + QSPI PSRAM, uses project-risc2-video-hw2.lpf
#
# Create & Manage:
#   make copyarch SRC=<arch> DST=<name>                     — copy an architecture
#   make delarch  ARCH=<name>                               — delete a user-created arch
#   make newgame  GAME=<name> ARCH=<arch>                   — scaffold a new game
#   make delgame  GAME=<name>                               — delete a user-created game
#
# Retro Computers (ARCH=pet, spectrum):
#   make download-rom ARCH=<arch>                           — download firmware ROMs
#   make download-cpu ARCH=<arch>                           — download CPU core (if needed)
#   make run ARCH=<arch>                                    — run retro computer simulation
#   make download-game ARCH=pet GAME=<name>                 — download a game
#   make run-game ARCH=pet GAME=<name>                      — run a game
#   make list-games ARCH=pet                                — list available games
#
# Setup:
#   make check-deps                                         — check installed tools
#
# Examples:
#   make run   GAME=char-snake ARCH=risc1 TARGET=verilator
#   make run   GAME=tic-tac-toe TARGET=sdl2
#   make run   GAME=labyrinth ARCH=riscv-darkrv TARGET=verilator
#   make run   GAME=labyrinth ARCH=riscv-darkrv TARGET=verilator RAM=psram HW=v2
#   make download-rom ARCH=spectrum
#   make run ARCH=pet
#
# RAM backing (RAM=, ARCH=riscv-darkrv for now):
#   bram   — on-chip BRAM (default).  Works on any HW.
#   sdram  — external SDRAM. Requires HW=v1.   (not yet implemented for riscv-darkrv)
#   psram  — external QSPI PSRAM. Requires HW=v2.
#   ddr3   — external DDR3.        Requires HW=v2.  (not yet validated on real HW)

# Load tool paths from .config.mk (generated by ./setup.sh)
-include .config.mk

ifeq ($(OS),Windows_NT)
  EXEEXT = .exe
else
  EXEEXT =
endif

# Prevent TARGET from leaking into sub-Makefiles (many use TARGET for binary name)
MAKEOVERRIDES := $(filter-out TARGET=%,$(MAKEOVERRIDES))

# ── Game/platform matrix ────────────────────────────────────────────────────
GAMES_RISC1 = char-snake
GAMES_RISC2 = gomoku tic-tac-toe char-gomoku labyrinth chess hello-pixels
GAMES_SDL2  = gomoku tic-tac-toe labyrinth char-gomoku chess hello-pixels

# Test/diagnostic tools live under util/ — not games. Built only by request.
UTIL_TOOLS = psram_test sound-test

# Resolve a game's per-platform Makefile directory.  Prefers the new flat
# layout (games/<game>/platforms/<arch>) and falls back to the legacy
# nested layout (games/<game>/src/platform/<arch>) for un-migrated games.
#   $(call gameplatdir,<game>,<arch>)
gameplatdir = $(if $(wildcard games/$(1)/platforms/$(2)/Makefile),games/$(1)/platforms/$(2),games/$(1)/src/platform/$(2))

# Newer "flat" layout: games/<game>/Makefile declares HAL_KIND and the arch's
# build.mk picks up the right HAL implementation.  Detect it by grepping for
# HAL_KIND in the top-level Makefile of the game — falls back to the legacy
# per-arch platform dir otherwise.  Usage in shell snippets:
#   if [ -n "$$(is_flat $(GAME))" ]; then ... ; fi
is_flat = $(if $(wildcard games/$(1)/Makefile),$(shell grep -l '^HAL_KIND' games/$(1)/Makefile 2>/dev/null),)

.PHONY: help all build run clean all-sdl2 all-risc1 all-risc2 gcasm check-deps copyarch delarch newgame delgame \
       download-rom download-cpu download-game run-game list-games \
       build-tool run-tool list-tools

